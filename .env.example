# Example environment. NAMES AND SAFE DEFAULTS ONLY — never put real secrets here.
# Real values live in an approved secret store, not in the repo.

# Control-plane API (local dev)
ASPNETCORE_ENVIRONMENT=Development
CONTROL_PLANE_API_URL=http://127.0.0.1:5080

# PostgreSQL (local dev container; not used until Phase 8)
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=labconnect_dev
POSTGRES_USER=labconnect
# POSTGRES_PASSWORD is intentionally omitted; set it in your local secret store.

# Gateway daemon (local dev)
GATEWAYD_BIND=127.0.0.1:5090
GATEWAYD_MODE=passive_capture
