{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lab-connect.invalid/schemas/canonical-model/0.1/result-set.json",
  "title": "ResultSet",
  "description": "Canonical laboratory result set (v0.1). Clinical numeric values are exact decimals encoded as strings; timestamps are RFC 3339 UTC. Mirrors the Rust canonical-model crate.",
  "type": "object",
  "required": ["id", "results"],
  "additionalProperties": false,
  "properties": {
    "id": { "$ref": "#/$defs/uuid" },
    "specimen": { "$ref": "#/$defs/uuid" },
    "results": { "type": "array", "items": { "$ref": "#/$defs/result" } }
  },
  "$defs": {
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "decimal": {
      "description": "Exact decimal as a string; never a JSON number (which would be a float).",
      "type": "string",
      "pattern": "^-?[0-9]+(\\.[0-9]+)?$"
    },
    "timestamp": {
      "description": "RFC 3339 UTC instant.",
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?(Z|[+-][0-9]{2}:[0-9]{2})$"
    },
    "coded": {
      "type": "object",
      "required": ["system", "code"],
      "additionalProperties": false,
      "properties": {
        "system": { "type": "string" },
        "code": { "type": "string" },
        "text": { "type": "string" }
      }
    },
    "resultValue": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "value"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "numeric" },
            "value": { "$ref": "#/$defs/decimal" },
            "unit": { "type": "string" }
          }
        },
        {
          "type": "object",
          "required": ["kind", "coded"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "coded" },
            "coded": { "$ref": "#/$defs/coded" }
          }
        },
        {
          "type": "object",
          "required": ["kind", "text"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "text" },
            "text": { "type": "string" }
          }
        },
        {
          "type": "object",
          "required": ["kind", "reason"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "absent" },
            "reason": {
              "enum": [
                "not_reported",
                "below_detection_limit",
                "above_detection_limit",
                "pending",
                "unknown"
              ]
            }
          }
        }
      ]
    },
    "referenceRange": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "low": { "$ref": "#/$defs/decimal" },
        "high": { "$ref": "#/$defs/decimal" },
        "text": { "type": "string" }
      }
    },
    "provenance": {
      "type": "object",
      "required": ["raw_message", "parser_version", "validation"],
      "additionalProperties": false,
      "properties": {
        "raw_message": { "$ref": "#/$defs/uuid" },
        "parser_version": { "type": "string" },
        "driver_version": { "$ref": "#/$defs/uuid" },
        "mapping_version": { "$ref": "#/$defs/uuid" },
        "validation": {
          "enum": ["pending_review", "held", "released", "rejected"]
        },
        "delivery": { "$ref": "#/$defs/uuid" },
        "acknowledgement": { "$ref": "#/$defs/uuid" }
      }
    },
    "result": {
      "type": "object",
      "required": ["id", "test", "value", "status", "provenance"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/uuid" },
        "test": { "$ref": "#/$defs/coded" },
        "value": { "$ref": "#/$defs/resultValue" },
        "status": {
          "enum": ["preliminary", "final", "corrected", "cancelled", "unknown"]
        },
        "flags": { "type": "array", "items": { "type": "string" } },
        "reference_range": { "$ref": "#/$defs/referenceRange" },
        "observed_at": { "$ref": "#/$defs/timestamp" },
        "provenance": { "$ref": "#/$defs/provenance" }
      }
    }
  }
}
