{
  "name": "@lab-connect/api-client",
  "version": "0.1.0",
  "private": true,
  "description": "Typed client for the control-plane and gateway REST APIs, built on shared contracts.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@lab-connect/contracts": "workspace:*"
  },
  "devDependencies": {
    "vitest": "4.1.10"
  }
}
