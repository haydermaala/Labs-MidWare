{
  "name": "lab-connect",
  "private": true,
  "version": "0.1.0",
  "description": "Cross-platform laboratory analyzer middleware — JS/TS workspace (desktop, web, shared packages).",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": ">=22.17.0 <23",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "typecheck": "pnpm -r --if-present run typecheck",
    "lint": "pnpm -r --if-present run lint",
    "test": "pnpm -r --if-present run test",
    "clean": "pnpm -r --if-present run clean"
  },
  "devDependencies": {
    "typescript": "5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
